---
interface Props {
  appName: string;
  lastUpdated: string;
  description?: string;
}

const { appName, lastUpdated, description } = Astro.props;
const pageTitle = `Política de Privacidad — ${appName}`;
const metaDesc = description ?? `Política de Privacidad de la aplicación ${appName}.`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDesc} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --brand: #4f46e5;
        --brand-dark: #3730a3;
        --brand-2: #7c3aed;
        --bg: #f8fafc;
        --card: #ffffff;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --highlight: #eef2ff;
        --warn-bg: #fffbeb;
        --warn-border: #fde68a;
        --warn-text: #78350f;
        --ok-bg: #f0fdf4;
        --ok-border: #bbf7d0;
        --ok-text: #14532d;
        --radius: 12px;
        --maxw: 780px;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        font-size: 1rem;
        line-height: 1.75;
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      /* ── Header ── */
      .site-header {
        background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand) 50%, var(--brand-2) 100%);
        padding: 48px 20px 56px;
        color: #fff;
        position: relative;
        overflow: hidden;
      }

      .site-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
      }

      .header-wrap {
        max-width: var(--maxw);
        margin: 0 auto;
        position: relative;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,0.75);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 20px;
        transition: color 0.15s;
      }

      .back-link:hover {
        color: #fff;
      }

      .app-chip {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        margin-bottom: 12px;
      }

      .header-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 700;
        margin: 0 0 10px;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }

      .header-desc {
        margin: 0 0 16px;
        font-size: 1rem;
        color: rgba(255,255,255,0.8);
        max-width: 54ch;
        line-height: 1.6;
      }

      .header-date {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8125rem;
        color: rgba(255,255,255,0.65);
        font-weight: 500;
      }

      .header-date svg {
        opacity: 0.7;
      }

      /* ── Main wrapper ── */
      .page-main {
        max-width: var(--maxw);
        margin: -28px auto 64px;
        padding: 0 20px;
        position: relative;
        z-index: 1;
      }

      /* ── Content card ── */
      .content-card {
        background: var(--card);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
        padding: 32px 36px;
      }

      @media (max-width: 600px) {
        .content-card {
          padding: 24px 20px;
        }
      }

      /* ── Typography inside card ── */
      .content-card h2 {
        font-size: 1.1875rem;
        font-weight: 700;
        color: var(--text);
        margin: 32px 0 10px;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--highlight);
        letter-spacing: -0.01em;
      }

      .content-card h2:first-child {
        margin-top: 0;
      }

      .content-card h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        margin: 20px 0 8px;
      }

      .content-card p {
        margin: 0 0 14px;
        color: var(--text);
      }

      .content-card ul,
      .content-card ol {
        margin: 4px 0 14px 1.25rem;
        padding: 0;
      }

      .content-card li {
        margin: 6px 0;
        color: var(--text);
      }

      .content-card a {
        color: var(--brand);
        text-decoration: none;
        border-bottom: 1px solid rgba(79,70,229,0.3);
        transition: border-color 0.15s;
      }

      .content-card a:hover {
        border-bottom-color: var(--brand);
      }

      .content-card strong {
        font-weight: 600;
      }

      .content-card code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.875em;
        background: var(--highlight);
        padding: 0.1em 0.35em;
        border-radius: 4px;
        color: var(--brand-dark);
      }

      /* ── TOC ── */
      .toc {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 20px;
        margin-bottom: 28px;
      }

      .toc-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin: 0 0 10px;
      }

      .toc ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 4px 0;
      }

      .toc li {
        width: 100%;
        margin: 0;
      }

      .toc a {
        font-size: 0.875rem;
        color: var(--muted);
        border: none;
        display: block;
        padding: 2px 0;
        transition: color 0.15s;
      }

      .toc a:hover {
        color: var(--brand);
        border: none;
      }

      /* ── Callout boxes ── */
      .callout {
        border-radius: 10px;
        padding: 14px 16px;
        margin: 16px 0;
        font-size: 0.9375rem;
      }

      .callout-warn {
        background: var(--warn-bg);
        border: 1px solid var(--warn-border);
        color: var(--warn-text);
      }

      .callout-ok {
        background: var(--ok-bg);
        border: 1px solid var(--ok-border);
        color: var(--ok-text);
      }

      .callout-info {
        background: var(--highlight);
        border: 1px solid #c7d2fe;
        color: var(--brand-dark);
      }

      /* ── Pills ── */
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 0.8125rem;
        font-weight: 600;
        background: var(--highlight);
        color: var(--brand-dark);
        border: 1px solid #c7d2fe;
        white-space: nowrap;
      }

      .pill-green {
        background: var(--ok-bg);
        color: var(--ok-text);
        border-color: var(--ok-border);
      }

      /* ── Divider ── */
      .divider {
        height: 1px;
        background: var(--border);
        margin: 24px 0;
      }

      /* ── Footer ── */
      .site-footer {
        max-width: var(--maxw);
        margin: 0 auto 56px;
        padding: 0 20px;
        text-align: center;
      }

      .footer-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 24px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .footer-contact {
        font-size: 0.875rem;
        color: var(--muted);
      }

      .footer-contact a {
        color: var(--brand);
        font-weight: 500;
        text-decoration: none;
      }

      .footer-contact a:hover {
        text-decoration: underline;
      }

      .footer-nav {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .footer-nav a {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.15s;
      }

      .footer-nav a:hover {
        color: var(--brand);
      }

      .footer-copy {
        width: 100%;
        font-size: 0.8125rem;
        color: #94a3b8;
        margin-top: 4px;
      }

      @media print {
        .site-header {
          background: #fff;
          color: #000;
          border-bottom: 2px solid #000;
        }
        .back-link, .app-chip { display: none; }
        .header-title, .header-desc, .header-date { color: #000; }
        .content-card { box-shadow: none; border: 1px solid #ccc; }
        .site-footer { display: none; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-wrap">
        <a href="/politicas" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Políticas de appsdemate.lat
        </a>
        <div class="app-chip">{appName}</div>
        <h1 class="header-title">Política de Privacidad</h1>
        <p class="header-desc">{metaDesc}</p>
        <span class="header-date">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Última actualización: {lastUpdated}
        </span>
      </div>
    </header>

    <main class="page-main">
      <div class="content-card">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="footer-card">
        <p class="footer-contact">
          ¿Preguntas? Escríbenos a <a href="mailto:jovannyrch@gmail.com">jovannyrch@gmail.com</a>
        </p>
        <nav class="footer-nav">
          <a href="/politicas">← Ver todas las políticas</a>
        </nav>
        <span class="footer-copy">© {new Date().getFullYear()} JovaSoft · appsdemate.lat</span>
      </div>
    </footer>
  </body>
</html>

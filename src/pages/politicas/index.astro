---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Políticas de Privacidad — appsdemate.lat</title>
    <meta
      name="description"
      content="Políticas de privacidad de todas las aplicaciones publicadas en appsdemate.lat (JovaSoft)."
    />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --brand: #4f46e5;
        --brand-dark: #3730a3;
        --brand-2: #7c3aed;
        --bg: #f8fafc;
        --card: #ffffff;
        --text: #0f172a;
        --muted: #64748b;
        --border: #e2e8f0;
        --highlight: #eef2ff;
        --radius: 14px;
        --maxw: 960px;
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* Hero */
      .hero {
        background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand) 50%, var(--brand-2) 100%);
        padding: 64px 24px 72px;
        color: #fff;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
      }

      .hero-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        position: relative;
      }

      .hero-eyebrow {
        display: inline-block;
        padding: 5px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        margin-bottom: 18px;
      }

      .hero h1 {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        margin: 0 0 14px;
        line-height: 1.15;
      }

      .hero p {
        font-size: 1.0625rem;
        color: rgba(255,255,255,0.8);
        max-width: 50ch;
        margin: 0 auto;
        line-height: 1.65;
      }

      /* Main */
      .main {
        max-width: var(--maxw);
        margin: -32px auto 72px;
        padding: 0 20px;
        position: relative;
        z-index: 1;
      }

      /* Stats strip */
      .stats {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 24px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px 32px;
        margin-bottom: 28px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
      }

      .stat {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: var(--muted);
      }

      .stat strong {
        color: var(--text);
        font-weight: 700;
        font-size: 1.1rem;
      }

      /* Grid */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
      }

      /* App card */
      .app-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 22px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
      }

      .app-card:hover {
        border-color: var(--brand);
        box-shadow: 0 4px 20px rgba(79,70,229,0.12);
        transform: translateY(-2px);
      }

      .card-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 8px;
      }

      .app-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--highlight);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.25rem;
      }

      .arrow {
        color: var(--muted);
        transition: color 0.15s, transform 0.15s;
        margin-top: 2px;
      }

      .app-card:hover .arrow {
        color: var(--brand);
        transform: translate(2px, -2px);
      }

      .app-name {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 4px;
        line-height: 1.3;
      }

      .app-desc {
        font-size: 0.8375rem;
        color: var(--muted);
        line-height: 1.55;
        margin: 0;
        flex: 1;
      }

      .card-footer {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        border-top: 1px solid var(--border);
        padding-top: 10px;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
      }

      .tag {
        font-size: 0.72rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 999px;
        white-space: nowrap;
      }

      .tag-green {
        background: #f0fdf4;
        color: #15803d;
        border: 1px solid #bbf7d0;
      }

      .tag-blue {
        background: var(--highlight);
        color: var(--brand-dark);
        border: 1px solid #c7d2fe;
      }

      .tag-gray {
        background: #f8fafc;
        color: var(--muted);
        border: 1px solid var(--border);
      }

      .card-date {
        font-size: 0.75rem;
        color: #94a3b8;
        white-space: nowrap;
      }

      /* Footer */
      .site-footer {
        text-align: center;
        padding: 24px;
        color: #94a3b8;
        font-size: 0.8125rem;
        border-top: 1px solid var(--border);
      }

      .site-footer a {
        color: var(--muted);
        text-decoration: none;
      }

      .site-footer a:hover {
        color: var(--brand);
      }
    </style>
  </head>
  <body>
    <section class="hero">
      <div class="hero-inner">
        <span class="hero-eyebrow">appsdemate.lat</span>
        <h1>Políticas de Privacidad</h1>
        <p>
          Aquí encontrarás la política de privacidad de cada aplicación publicada por
          <strong>JovaSoft</strong>. Selecciona una app para conocer cómo se trata tu información.
        </p>
      </div>
    </section>

    <main class="main">
      <div class="stats">
        <div class="stat"><strong>{apps.length}</strong> aplicaciones publicadas</div>
        <div class="stat">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Comprometidos con tu privacidad
        </div>
        <div class="stat">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Cumplimiento Google Play
        </div>
      </div>

      <div class="grid">
        {apps.map((app) => (
          <a href={`/politicas/${app.slug}`} class="app-card">
            <div class="card-head">
              <div class="app-icon">📱</div>
              <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"/>
                <polyline points="7 7 17 7 17 17"/>
              </svg>
            </div>
            <div>
              <p class="app-name">{app.name}</p>
              <p class="app-desc">{app.desc}</p>
            </div>
            <div class="card-footer">
              <div class="tags">
                {app.tags.map((tag) => (
                  <span class={`tag tag-${tagColor[tag] ?? 'gray'}`}>{tag}</span>
                ))}
              </div>
              <span class="card-date">Act. {app.updated}</span>
            </div>
          </a>
        ))}
      </div>
    </main>

    <footer class="site-footer">
      <p>
        © {new Date().getFullYear()} JovaSoft ·
        <a href="mailto:jovannyrch@gmail.com">jovannyrch@gmail.com</a>
      </p>
    </footer>
  </body>
</html>
